# Ghost Protocol v2.0 — Environment Variables
# Copy this file to .env and fill in your values.

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key

# ── LLM Providers ─────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
# Free at: https://console.groq.com

GEMINI_API_KEY=your-gemini-api-key
# Free at: https://aistudio.google.com/app/apikey

HF_API_KEY=your-huggingface-api-key
# Free at: https://huggingface.co/settings/tokens

# ── Embeddings ────────────────────────────────────────────
JINA_API_KEY=your-jina-api-key
# Free at: https://jina.ai (1M tokens/month)

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_CHAT_ID=123456789

# ── WhatsApp Fallback (CallMeBot) ─────────────────────────
# Activation: Send "I allow callmebot to send me messages" to +34 644 597 071 on WhatsApp
# then use the API key they reply with.
CALLMEBOT_API_KEY=your-callmebot-api-key
CALLMEBOT_PHONE=+91XXXXXXXXXX   # Your WhatsApp number with country code

# ── Email (Gmail SMTP) ────────────────────────────────────
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
# Generate at: https://myaccount.google.com/apppasswords

# ── Scheduler ─────────────────────────────────────────────
DEFAULT_TIMEZONE=Asia/Kolkata

# ── Target Roles (comma-separated, used by orchestrator) ──
TARGET_ROLES=ML Engineer,AI Engineer,Data Scientist,Research Intern,NLP Engineer

# ── Legacy (v1 — no longer required in v2) ────────────────
# SERPAPI_API_KEY=  ← replaced by free APIs
# APOLLO_API_KEY=   ← unused
# SNOV_CLIENT_ID=   ← unused
# SNOV_CLIENT_SECRET= ← unused
